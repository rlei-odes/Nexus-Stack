---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Database" activeNav="database">
  <div class="card-grid">
    <div class="card">
      <h3>Logs</h3>
      <div class="count" id="logsCount">-</div>
      <p>Workflow and system logs</p>
      <a href="/logs" class="btn-primary">View Logs</a>
    </div>
    <div class="card">
      <h3>Config</h3>
      <div class="count" id="configCount">-</div>
      <p>Configuration entries</p>
    </div>
    <div class="card">
      <h3>Services</h3>
      <div class="count" id="servicesCount">-</div>
      <p>Registered services</p>
    </div>
  </div>

  <div class="section">
    <h2>Config Table</h2>
    <div class="actions">
      <button class="btn-primary" onclick="loadDatabase()">Refresh</button>
    </div>
    <table>
      <thead>
        <tr><th>Key</th><th>Value</th><th>Updated</th></tr>
      </thead>
      <tbody id="configTable">
        <tr><td colspan="3" class="empty">Loading...</td></tr>
      </tbody>
    </table>
  </div>

  <div class="section">
    <h2>Services Table</h2>
    <table>
      <thead>
        <tr><th>Name</th><th>Subdomain</th><th>Port</th><th>Enabled</th><th>Deployed</th><th>Category</th></tr>
      </thead>
      <tbody id="servicesTable">
        <tr><td colspan="6" class="empty">Loading...</td></tr>
      </tbody>
    </table>
  </div>
</Layout>

<style>
  .section {
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 1.5rem;
    margin-bottom: 1.5rem;
  }

  .actions {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }

  .card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1.5rem;
    margin-bottom: 2rem;
  }

  .card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 1.5rem;
    transition: border-color 0.2s;
  }

  .card:hover { border-color: var(--accent); }

  .card h3 {
    color: var(--accent);
    font-size: 1rem;
    margin-bottom: 0.5rem;
  }

  .card p {
    color: var(--text-secondary);
    font-size: 0.85rem;
    margin-bottom: 1rem;
  }

  .card .count {
    font-size: 2rem;
    color: var(--text-primary);
    margin-bottom: 0.5rem;
  }

  .key { color: var(--accent); font-weight: 500; }
  .value { color: var(--text-primary); }
  .timestamp { color: var(--text-muted); font-size: 0.8rem; }
  .enabled { color: var(--accent); }
  .disabled { color: var(--error); }
  .empty { text-align: center; padding: 2rem; color: var(--text-secondary); }
</style>

<script is:inline>
  async function loadDatabase() {
    try {
      // Load config
      const configRes = await fetch('/api/logs?limit=1');
      const configData = await configRes.json();

      // Load services
      const svcRes = await fetch('/api/services');
      const svcData = await svcRes.json();

      if (svcData.success) {
        const services = svcData.services || [];
        document.getElementById('servicesCount').textContent = services.length;

        const tbody = document.getElementById('servicesTable');
        if (services.length === 0) {
          tbody.innerHTML = '<tr><td colspan="6" class="empty">No services</td></tr>';
        } else {
          tbody.innerHTML = services.map(s =>
            '<tr>' +
            '<td class="key">' + escapeHtml(s.name) + '</td>' +
            '<td>' + escapeHtml(s.subdomain || '-') + '</td>' +
            '<td>' + (s.port || '-') + '</td>' +
            '<td class="' + (s.enabled ? 'enabled' : 'disabled') + '">' + (s.enabled ? 'Yes' : 'No') + '</td>' +
            '<td class="' + (s.deployed ? 'enabled' : 'disabled') + '">' + (s.deployed ? 'Yes' : 'No') + '</td>' +
            '<td>' + escapeHtml(s.category || '-') + '</td>' +
            '</tr>'
          ).join('');
        }
      }

      // Load config table via info API
      const infoRes = await fetch('/api/info');
      const infoData = await infoRes.json();
      if (infoData.success) {
        const configTable = document.getElementById('configTable');
        const info = infoData.info || {};
        const rows = [];

        if (info.server) {
          Object.entries(info.server).forEach(([k, v]) => {
            rows.push('<tr><td class="key">' + escapeHtml(k) + '</td><td class="value">' + escapeHtml(String(v || '')) + '</td><td class="timestamp">-</td></tr>');
          });
        }

        document.getElementById('configCount').textContent = rows.length;
        configTable.innerHTML = rows.length > 0 ? rows.join('') : '<tr><td colspan="3" class="empty">No config entries</td></tr>';
      }

      // Log count
      const logsRes = await fetch('/api/logs?limit=1');
      const logsData = await logsRes.json();
      if (logsData.success) {
        document.getElementById('logsCount').textContent = logsData.total || (logsData.logs || []).length;
      }
    } catch (error) {
      console.error('Failed to load database:', error);
    }
  }

  loadDatabase();
</script>
